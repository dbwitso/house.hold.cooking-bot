# Telegram Bot API
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your household Telegram group chat ID (negative number, e.g., -1001234567890)
GROUP_CHAT_ID=your_group_chat_id_here

# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/cooking_bot

# Port for the webhook server
PORT=3000

# Timezone
TZ=Africa/Lusaka

# Node environment
NODE_ENV=development
